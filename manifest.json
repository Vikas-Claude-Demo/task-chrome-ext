{
  "manifest_version": 3,
  "name": "Nudge",
  "version": "3.0.0",
  "description": "Save follow-up tasks from LinkedIn, Gmail, Outlook and WhatsApp with smart reminders",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.linkedin.com/messaging/",
    "https://www.linkedin.com/messaging/*",
    "https://mail.google.com/*",
    "https://outlook.live.com/mail/*",
    "https://outlook.office.com/mail/*",
    "https://web.whatsapp.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/messaging/",
        "https://www.linkedin.com/messaging/*",
        "https://mail.google.com/*",
        "https://outlook.live.com/mail/*",
        "https://outlook.office.com/mail/*",
        "https://web.whatsapp.com/*"
      ],
      "js": ["shared/config.js", "shared/firebase-storage.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Nudge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
